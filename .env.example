# Trading Bot - Environment Variables Template
# Copy this to .env and fill in your actual values

# === ETrade API ===
ETORO_API_KEY=
ETORO_USER_KEY=

# === Kraken API ===
KRAKEN_API_KEY=
KRAKEN_SECRET_KEY=

# === Coinbase API ===
COINBASE_API_KEY=
COINBASE_SECRET_KEY=
COINBASE_PASSPHRASE=

# === Database ===
DATA_DIR=./data
SQLITE_DB=./data/trading_bot.db

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Paper Trading ===
PAPER_TRADING=true
INITIAL_CAPITAL_USD=10000

# === Trading ===
DEFAULT_TICKERS=BTC/USD,ETH/USD,SOL/USD
HISTORY_DAYS=365
